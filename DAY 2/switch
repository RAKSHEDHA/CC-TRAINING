#include <stdio.h>

int main()
{
    char a;

    printf("Enter a character: ");
    scanf("%c", &a);

    switch(a)
    {
        case 'A' ... 'Z':
            printf("Uppercase");
            break;

        case 'a' ... 'z':
            printf("Lowercase");
            break;

        case '0' ... '9':
            printf("Number");
            break;

        default:
            printf("Special Character");
    }

    return 0;
}